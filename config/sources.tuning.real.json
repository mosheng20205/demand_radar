{
  "database_path": "data/tuning_real.db",
  "min_score": 20,
  "notify_min_score": 999,
  "export_path": "exports/leads.real.csv",
  "health_export_path": "exports/source_health.csv",
  "top_leads_export_path": "exports/top20_leads.csv",
  "theme_export_path": "exports/opportunity_themes.csv",
  "product_directions_export_path": "exports/product_directions.csv",
  "top_leads_limit": 20,
  "product_directions_limit": 5,
  "log_path": "logs/demand_radar.log",
  "log_level": "INFO",
  "failure_control": {
    "alert_threshold": 3,
    "cooldown_minutes": 120,
    "backoff_multiplier": 2.0
  },
  "daily_summary": {
    "enabled": false,
    "hour_local": 21
  },
  "fetch": {
    "timeout_seconds": 8,
    "retries": 0,
    "backoff_seconds": 1,
    "user_agent": "DemandRadar/0.1 (+real-tuning-pass)"
  },
  "cloak": {
    "api_base_url": "${DEMAND_RADAR_CLOAK_API_BASE_URL}",
    "profile_id": "${DEMAND_RADAR_ZBJ_PROFILE_ID}",
    "profile_name": "${DEMAND_RADAR_ZBJ_PROFILE_NAME}",
    "close_after_fetch": true,
    "queue": true,
    "timeout_seconds": 20
  },
  "notifications": {
    "wecom": { "enabled": false, "webhook_url": "" },
    "feishu": { "enabled": false, "webhook_url": "" },
    "email": {
      "enabled": false,
      "host": "",
      "port": 465,
      "username": "",
      "password": "",
      "from_addr": "",
      "to_addrs": [],
      "use_ssl": true
    }
  },
  "keyword_rules": {
    "high_intent": {
      "score": 25,
      "keywords": ["求代做", "求购买", "求脚本", "求工具", "悬赏", "接定制", "有没有现成方案", "need help", "custom tool", "looking for alternative", "looking for tool", "looking for script"]
    },
    "high_frequency": {
      "score": 15,
      "keywords": ["每天", "经常", "批量", "自动", "一直", "老是", "反复", "every day", "often", "batch", "automate", "repeatedly", "daily", "bulk"]
    },
    "pain": {
      "score": 12,
      "keywords": ["太贵", "太麻烦", "掉线", "不稳定", "报错", "效率太低", "麻烦", "不好用", "卡顿", "漏掉", "too expensive", "painful", "unstable", "slow", "hard to use", "errors", "hard to troubleshoot", "scattered", "manual", "time-consuming", "too many clicks"]
    },
    "value_actions": {
      "score": 10,
      "keywords": ["监控", "提醒", "导出", "对账", "归档", "去重", "汇总", "同步", "匹配", "转换", "monitor", "alert", "export", "reconcile", "archive", "dedupe", "sync", "match", "convert", "dashboard", "report", "notification"]
    },
    "budget": {
      "score": 20,
      "keywords": ["预算", "报价", "多少钱", "付费", "年费", "月费", "价格", "budget", "price", "pricing", "monthly", "annual"]
    },
    "ecommerce_ops": {
      "score": 14,
      "keywords": ["店铺", "抖店", "订单", "售后", "库存", "上架", "多店铺", "客服", "日报", "对账", "店群", "商家", "商品", "运营", "erp", "crm", "workflow", "inventory", "order", "ticket", "merchant"]
    },
    "risky": {
      "score": -40,
      "keywords": ["盗号", "撞库", "绕过支付", "隐私窃取", "黑产", "洗号", "stolen account", "credential stuffing", "bypass payment"]
    }
  },
  "theme_rules": {
    "高级自动化仍需代码支持": ["custom", "programming", "developer", "api", "documentation", "advanced", "代码", "开发"],
    "自动化任务定价和ROI不透明": ["pricing", "price", "expensive", "roi", "monthly", "annual", "成本", "预算"],
    "自动化执行故障排查困难": ["error", "troubleshoot", "delay", "duplicate", "missing features", "bad configuration", "异常", "告警"],
    "移动端和实时告警能力不足": ["mobile", "ios", "android", "notify", "notification", "late", "实时"],
    "企业支持和实施服务存在缺口": ["support", "enterprise", "customer support", "expert programmer", "实施", "顾问"]
