    },
    "budget": {
      "score": 20,
      "keywords": ["预算", "报价", "付费", "价格", "budget", "price", "pricing"]
    },
    "risky": {
      "score": -40,
      "keywords": ["盗号", "撞库", "隐私窃取", "stolen account", "credential stuffing"]
    }
  },
  "source_score_bonus": {
    "demand_market": 18,
    "service_titles": 15,
    "social_hot_posts": 8,
    "social_comments": 8
  },
